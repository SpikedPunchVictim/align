{
  "name": "@spikedpunch/align-cli",
  "version": "0.1.4",
  "description": "align CLI — an architecture-conformance verification oracle for LLM coding agents, with a built-in MCP server.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SpikedPunchVictim/align",
    "directory": "packages/cli"
  },
  "keywords": [
    "align",
    "architecture",
    "conformance",
    "cli",
    "mcp",
    "model-context-protocol",
    "dependency-graph",
    "static-analysis"
  ],
  "type": "module",
  "bin": {
    "align": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@spikedpunch/align-agent": "workspace:*",
    "@spikedpunch/align-core": "workspace:*",
    "@spikedpunch/align-plugin-typescript": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "commander": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "@types/node": "^22.9.0"
  }
}
