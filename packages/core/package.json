{
  "name": "@spikedpunch/align-core",
  "version": "0.1.2",
  "description": "Zero-dependency architecture-conformance rule engine for align: the DSL, JSON IR schema, gate stack, and baseline.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SpikedPunchVictim/align",
    "directory": "packages/core"
  },
  "keywords": [
    "align",
    "architecture",
    "conformance",
    "dependency-graph",
    "dependency-direction",
    "import-cycle",
    "static-analysis",
    "dsl",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dsl": {
      "types": "./dist/dsl/index.d.ts",
      "default": "./dist/dsl/index.js"
    },
    "./fix": {
      "types": "./dist/fix/index.d.ts",
      "default": "./dist/fix/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
