exports[`defineProject > golden snapshot: maxLinesPerFile compiles to a stable arch.metric IR shape 1`] = `
{
  "components": {
    "api": {
      "allowEmpty": false,
      "name": "api",
      "selector": {
        "kind": "glob",
        "patterns": [
          "application/api/**",
        ],
